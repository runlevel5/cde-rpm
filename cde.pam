#%PAM-1.0
# PAM configuration for the CDE display manager (dtlogin).
# Delegate to Fedora's system-auth stack for all four phases. Previous
# versions tried to mimic gdm's hand-rolled stack, but that included
# pam_console.so (removed from Fedora long ago) and pam_namespace.so
# in a way that caused pam_unix to report "user unknown" during auth.
auth     include  system-auth
account  include  system-auth
password include  system-auth
session  include  system-auth

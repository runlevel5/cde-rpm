From: Trung Le <trung.le@ruby-journal.com>
Subject: tttypes: drop /usr/dt from dtinfo ptype start strings

The DtInfo / DtInfoPrint / DtInfo_Start ToolTalk ptypes hardcode the
legacy /usr/dt/infolib/etc/dtinfo_start and /usr/dt/bin/dtinfo paths.
These strings end up baked into the compiled types.xdr database that
ttsession reads, so changing CDE_INSTALLATION_TOP / CDE_DATA_TOP via
configure does NOT redirect them. On an FHS install the legacy paths
do not exist, ToolTalk reports

    TT_ERR_PTYPE_START -- Attempt to launch instance of ptype failed

when the desktop sends DtInfo_LoadInfoLib, and dtinfo never opens.

Rewrite the start strings to the FHS-correct binaries. The .ptype
files are not run through tradcpp at build time, so the simplest
fix is a literal swap. The data dirs match the layout enforced by
Patch0008 + Patch0010.

--- a/programs/tttypes/dtinfo.ptype
+++ b/programs/tttypes/dtinfo.ptype
@@ -13,7 +13,7 @@
 #include "dtinfo_start.opnums"

 ptype DtInfo {
-       	start 	"/usr/dt/infolib/etc/dtinfo_start";
+       	start 	"/usr/share/cde/infolib/etc/dtinfo_start";
 	handle:
 		session DtInfo_LoadInfoLib (
 				in string action_name,
@@ -32,7 +32,7 @@ ptype DtInfo {
 }

 ptype DtInfoPrint {
-      start "/usr/dt/bin/dtinfo -print";
+      start "/usr/bin/dtinfo -print";
       handle:

       /* print a specified section */
--- a/programs/tttypes/dtinfo_start.ptype
+++ b/programs/tttypes/dtinfo_start.ptype
@@ -13,7 +13,7 @@
 #include "dtinfo_start.opnums"

 ptype DtInfo_Start {
-	start 	"/usr/dt/infolib/etc/dtinfo_start";
+	start 	"/usr/share/cde/infolib/etc/dtinfo_start";
 	handle:
 		session DtInfo_LoadInfoLib (
 				in string action_name,
